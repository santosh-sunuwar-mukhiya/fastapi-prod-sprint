# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./test.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/auth_db
# For SQLite (async): sqlite+aiosqlite:///./auth.db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@example.com
SENDER_NAME=Auth System

# API Configuration
API_TITLE=Auth System API
API_VERSION=1.0.0
API_DESCRIPTION=JWT + Email Verification Authentication System
DEBUG=True
ENVIRONMENT=development

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8000
RELOAD=True

# Security
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Token Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Verification
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=24

# Password Requirements
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=true
REQUIRE_NUMBERS=true
REQUIRE_SPECIAL_CHARS=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
